{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 10
    },
    "api/seed.ts": {
      "maxDuration": 30,
      "includeFiles": "public/**"
    }
  }
}


