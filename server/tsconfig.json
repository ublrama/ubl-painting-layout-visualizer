{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "..",
    "outDir": "../dist-server",
    "noEmit": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    // strict and noImplicitAny are disabled because the existing api/*.ts files
    // use untyped Supabase generics (no Database type param) which produce errors
    // under strict checking. Those files are not modified per project constraints.
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "resolveJsonModule": true
  },
  "include": ["index.ts"]
}
