# Frontend (Vite — must be prefixed VITE_)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # "anon public" key from Supabase dashboard → Settings → API

# Backend API (server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Seed protection (optional)
SEED_SECRET=your-random-secret-here
